---
import SocialRow from '../SocialRow.astro';
---

<style>
    footer {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--color-text);
        font-size: 0.875rem;
        margin-top: 2rem;
    }

    .back-to-top {
        display: inline-block;
        margin-bottom: 1rem;
        transition: transform 0.2s;
    }

    .back-to-top:hover {
        transform: scale(1.1);
    }

    .back-to-top .logo-container {
        position: relative;
        display: inline-block;
        width: 48px;
    }

    .back-to-top img {
        width: 48px;
        height: auto;
        display: block;
        transition: opacity 0.2s;
    }

    .back-to-top .logo-hover {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
    }

    .back-to-top:hover .logo-default {
        opacity: 0;
    }

    .back-to-top:hover .logo-hover {
        opacity: 1;
    }
</style>

<footer>
    <a href="#" class="back-to-top" aria-label="Back to top">
        <span class="logo-container">
            <img class="logo-default" src="/logo_hvit.png" alt="DVD logo" />
            <img class="logo-hover" src="/dvd_logo.png" alt="DVD logo" />
        </span>
    </a>
    <div style="margin-bottom: 1rem; display: flex; justify-content: center;">
        <SocialRow />
    </div>

    © {new Date().getFullYear()} Din Våte Drøm. All rights reserved.

<script>
    document.querySelector('.back-to-top')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
</script>
</footer>