---
import '../../styles/global.css';
import BandLogo from '../BandLogo.astro';
import ScrollIndicator from '../ScrollIndicator.astro';
import SocialRow from '../SocialRow.astro';
---

<style>
    .centered-splash {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .coming-soon {
        font-size: 2rem;
        font-weight: 800;
        font-family: 'Montserrat', 'Segoe UI', system-ui, sans-serif;
        letter-spacing: 0.05em;
        margin: -0.5rem 0 0 0;
        color: var(--color-primary);
    }
</style>

<div class="centered-splash">
    <BandLogo />
    <ScrollIndicator />
    <div style="margin-top: 3rem;">
        <SocialRow />
    </div>
</div>